# Optional overrides for docker compose / seed (defaults match docker-compose.yml).

POSTGRES_USER=olympics
POSTGRES_PASSWORD=olympics
POSTGRES_DB=olympics
POSTGRES_PORT=5432

MONGO_PORT=27017
MONGO_DB=olympics

# Hugging Face dataset (public; no token required for resolve/main CSVs)
HF_DATASET_REPO=SVeldman/126-years-olympic-results
HF_DATASET_REVISION=main

# Seed CSV cache directory (compose bind-mounts it for seed)
HF_DATASET_CACHE=./data/cache

# OpenRouter API key and model
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# MCP Toolbox (port matches docker-compose.yml)
TOOLBOX_BASE_URL=http://127.0.0.1:5050
